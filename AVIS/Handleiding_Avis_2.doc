\par Gebiedscode, Gebiedsnaam, Oppervlakte, Euringnummer, Soort, Jaar1, Jaar2, Jaar3,etc.
\par 
\par }{\f0\cf17 \emdash }{\cf17 gegevens gescheiden door komma's-----------aantal paren per jaar per soort-------
\par 
\par Een voorbeeld van een import-bestand vindt u hieronder:
\par 
\par Gebiedscode,Gebiedsnaam,Oppervlakte,Euringnummer,Soort,1990,1991,1992
\par 10000001,Oostereng Natuurbos1,110.4,2310,Wespendief,1,,1
\par 10000001,Oostereng Natuurbos1,110.4,2670,Havik,1,1,2
\par 10000001,Oostereng Natuurbos1,110.4,2690,Sperwer,,1,
\par 10000001,Oostereng Natuurbos1,110.4,2870,Buizerd,2,1,3
\par 10000001,Oostereng Natuurbos1,110.4,3100,Boomvalk,,,1
\par 10000001,Oostereng Natuurbos1,110.4,5290,Houtsnip,1,1,3
\par 10000001,Oostereng Natuurbos1,110.4,7610,Bosuil,-1,,2
\par 10000001,Oostereng Natuurbos1,110.4,7670,Ransuil,,,1
\par 
