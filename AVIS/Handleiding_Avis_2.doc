\tx0\tx720\tx1440\tx2160\tx2880\tx3600\tx4320\tx5040\tx5760\tx6480\tx7200\tx7920\tx8640\faauto\rin0\lin0\itap0 \v\f1\fs20\cf17\lang1043\langfe1043\cgrid\langnp1043\langfenp1043 {\xe {\cf17 }{\f11\cf17 Vogelgroep verwijderen}{\cf17 }}}{\f0\cf17 \'94}{
