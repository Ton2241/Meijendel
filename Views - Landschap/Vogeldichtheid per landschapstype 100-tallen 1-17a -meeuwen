/* 
UITLEG
Vogeldichtheid per honderdtal (100, 200, 300, ...) als percentage per jaar.
Subgroepen (101, 102, ...) worden genegeerd als er ook een honderdtal-koppeling is.
Alle meeuwensoorten worden uitgesloten (soort_naam bevat 'meeuw').
Alleen plots 1 t/m 17 met optionele letter A/B worden meegenomen, maar 17B wordt uitgesloten.
*/

WITH geselecteerde_plots AS (
  -- Stap 1: Selecteer plots 1..17 met optionele letter (A/B/…),
  -- maar sluit 17B expliciet uit.
  SELECT plot_id, kavel_nummer
  FROM plots
  WHERE kavel_nummer REGEXP '^([1-9]|1[0-7])([a-zA-Z])?$'
    AND UPPER(kavel_nummer) != '17B'
),

vogel_honderdtallen AS (
  -- Stap 2: Neem alleen koppelingen met honderdtallen (100, 200, ...)
  -- Subgroepen (101, 102, ...) tellen hier niet mee
  -- Sluit alle meeuwensoorten uit op basis van soort_naam
  SELECT DISTINCT
    vg.groepsnummer,
    vg.vogel_id
  FROM evg_vogel_landschapgroep vg
  JOIN soorten s ON s.id = vg.vogel_id
  WHERE vg.groepsnummer % 100 = 0
    AND LOWER(s.soort_naam) NOT LIKE '%meeuw%'
),

actieve_oppervlakte AS (
  -- Stap 3: Bereken per jaar de totale oppervlakte van de geselecteerde plots
  SELECT 
    w.jaar,
    SUM(pjo.oppervlakte_km2) AS totaal_oppervlak_km2
  FROM (SELECT DISTINCT jaar, plot_id FROM territoria) w
  INNER JOIN geselecteerde_plots gp ON w.plot_id = gp.plot_id
  INNER JOIN plot_jaar_oppervlak pjo ON w.plot_id = pjo.plot_id AND w.jaar = pjo.jaar
  WHERE w.jaar BETWEEN 1958 AND 2025
  GROUP BY w.jaar
),

dichtheid_per_honderdtal AS (
  -- Stap 4: Bereken per jaar en per honderdtal de dichtheid
  -- (som territoria / totale oppervlakte)
  SELECT 
    vh.groepsnummer,
    w.jaar,
    SUM(COALESCE(w.territoria, 0)) / ao.totaal_oppervlak_km2 AS groep_dichtheid
  FROM vogel_honderdtallen vh
  INNER JOIN territoria w ON vh.vogel_id = w.soort_id
  INNER JOIN geselecteerde_plots gp ON w.plot_id = gp.plot_id
  INNER JOIN actieve_oppervlakte ao ON w.jaar = ao.jaar
  GROUP BY vh.groepsnummer, w.jaar, ao.totaal_oppervlak_km2
),

jaar_totalen AS (
  -- Stap 5: Totaal van alle groepsdichtheden per jaar
  SELECT jaar, SUM(groep_dichtheid) AS totaal_dichtheid_jaar
  FROM dichtheid_per_honderdtal
  GROUP BY jaar
),

data_bron AS (
  -- Stap 6: Zet de groepsdichtheid om naar een percentage van het jaartotaal
  SELECT 
    dpg.groepsnummer,
    ROUND((dpg.groep_dichtheid / jt.totaal_dichtheid_jaar) * 100, 2) AS percentage,
    dpg.jaar
  FROM dichtheid_per_honderdtal dpg
  JOIN jaar_totalen jt ON dpg.jaar = jt.jaar
)

-- Stap 7: Maak een matrix met per honderdtal de percentages per jaar (1958–2025)
